# GreenWave Backend Environment Configuration
# Copy this file to .env and update values as needed

# Application Settings
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./greenwave.db
# For PostgreSQL: postgresql://user:password@localhost/greenwave
# For MySQL: mysql://user:password@localhost/greenwave

# GPS Configuration
GPS_SPEED_THRESHOLD_KMH=70
GPS_ACCELERATION_THRESHOLD_KMH_S=15

# Corridor Configuration
CORRIDOR_SIGNAL_GREEN_TIME=30
CORRIDOR_SIGNAL_INTERVAL=2

# SMS Configuration
SMS_SERIAL_PORT=/dev/ttyUSB0
SMS_BAUD_RATE=9600
SMS_MAX_RETRIES=1

# Hardware Monitoring
HARDWARE_HEALTH_CHECK_INTERVAL=30
HARDWARE_TEMP_SENSOR=/sys/class/thermal/thermal_zone0/temp

# Demo/Simulation
DEMO_SPAWN_RADIUS_KM=5
DEMO_CITY_CENTER_LAT=23.1815
DEMO_CITY_CENTER_LNG=72.5371

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:5174"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_WORKERS=4
